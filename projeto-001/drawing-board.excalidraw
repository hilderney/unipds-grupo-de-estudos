      "index": "bW7",
      "roundness": null,
      "seed": 1841220361,
      "version": 222,
      "versionNonce": 1958937504,
      "isDeleted": true,
      "boundElements": [
        {
          "id": "aQAcKZfmmCrlfFt-zZZzT",
          "type": "arrow"
        }
      ],
      "updated": 1782521087651,
      "link": null,
      "locked": false,
      "text": "C — Context: qual o pano de fundo, informações de base que o modelo precisa.  ￼\nL — Language: qual a língua, estilo, formato esperado de linguagem.  ￼\nE — Expectations: o que exatamente o modelo deve produzir (resultados mínimos, requisitos).  ￼\nA — Actions: que passos ou fluxo o modelo deve seguir.  ￼\nR — Results: como deve aparecer o resultado final, qual formato, testes, exemplos.  ￼",
      "fontSize": 28,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "C — Context: qual o pano de fundo, informações de base que o modelo precisa.  ￼\nL — Language: qual a língua, estilo, formato esperado de linguagem.  ￼\nE — Expectations: o que exatamente o modelo deve produzir (resultados mínimos, requisitos).  ￼\nA — Actions: que passos ou fluxo o modelo deve seguir.  ￼\nR — Results: como deve aparecer o resultado final, qual formato, testes, exemplos.  ￼",
      "autoResize": true,
      "lineHeight": 1.25
    },
