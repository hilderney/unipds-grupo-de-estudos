    {
      "id": "2kIoSNs-V0yhHXw0ffvO_",
      "type": "text",
      "x": 876.9987345958742,
      "y": 3822.274836425799,
      "width": 1302.4473876953125,
      "height": 175,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
