    },
    {
      "id": "YcY3vvLxHX7bOAisMjQjn",
      "type": "text",
      "x": -2507.982697515989,
      "y": 11527.24862125195,
      "width": 484.142575514745,
      "height": 150,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#a5d8ff",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "dashed",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bRbm",
      "roundness": null,
      "seed": 410620420,
      "version": 550,
      "versionNonce": 1347106400,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1782521087651,
      "link": null,
      "locked": false,
      "text": "“Tools” são funções JavaScript que você registra\nno cliente do Modelo (OpenIA).\n\nO modelo pode chamá-las automaticamente\ndurante a conversa, quando entender que elas\najudam a cumprir a tarefa.",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "“Tools” são funções JavaScript que você registra no cliente do Modelo (OpenIA).\n\nO modelo pode chamá-las automaticamente durante a conversa, quando entender que elas ajudam a cumprir a tarefa.",
      "autoResize": false,
      "lineHeight": 1.25
    },
