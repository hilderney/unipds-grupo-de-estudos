      "updated": 1782521087652,
      "link": null,
      "locked": false,
      "text": "enum Role {\n  user\n  system\n  assistant\n  tool\n}\n\nmodel Message {\n    id String @id @default(uuid())\n    role Role @default(user)\n    tool_calls String?\n    tool_call_id String?\n    content String\n    chatId String @default(uuid())\n    createdAt DateTime @default(now())\n}\n",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "enum Role {\n  user\n  system\n  assistant\n  tool\n}\n\nmodel Message {\n    id String @id @default(uuid())\n    role Role @default(user)\n    tool_calls String?\n    tool_call_id String?\n    content String\n    chatId String @default(uuid())\n    createdAt DateTime @default(now())\n}\n",
      "autoResize": true,
      "lineHeight": 1.25
