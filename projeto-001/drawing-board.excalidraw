    },
    {
      "id": "P0WMzhA5hbLOE2Ol9eFym",
      "type": "text",
      "x": -2004.338037293919,
      "y": 8920.613617646715,
      "width": 397.31314394477357,
      "height": 75,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "dashed",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bRdm",
      "roundness": null,
      "seed": 487335610,
      "version": 1268,
      "versionNonce": 361179040,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1782521087651,
      "link": null,
      "locked": false,
      "text": "Mensagens promocionais, de\nengajamento, lançamentos, ofertas ou\nre‑ativação de clientes.",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Mensagens promocionais, de engajamento, lançamentos, ofertas ou re‑ativação de clientes.",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "g2gvhL1cytPkrZfJO3L-R",
      "type": "text",
      "x": -2008.334583334177,
      "y": 9182.114956122481,
      "width": 368.593854257204,
      "height": 100,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "dashed",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bRdmV",
      "roundness": null,
      "seed": 738613414,
      "version": 1242,
      "versionNonce": 1201185376,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1782521087651,
      "link": null,
      "locked": false,
      "text": "Mensagens transacionais ou de\nserviço que se relacionam a uma\nação/conversação que o usuário já\niniciou ou é essencial para ele.",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Mensagens transacionais ou de serviço que se relacionam a uma ação/conversação que o usuário já iniciou ou é essencial para ele.",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "VwZ8B3qe3aAESGTok2D0o",
      "type": "text",
      "x": -1440.0369914649452,
      "y": 8920.940504980903,
      "width": 406.50814397059895,
      "height": 100,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "dashed",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bRdn",
      "roundness": null,
      "seed": 1305462374,
      "version": 1303,
      "versionNonce": 360788896,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1782521087651,
      "link": null,
      "locked": false,
      "text": "Mensagens para verificação de\nidentidade, como códigos OTP (one‑time\npassword), autenticação de login ou\nrecuperação de conta.",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Mensagens para verificação de identidade, como códigos OTP (one‑time password), autenticação de login ou recuperação de conta.",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "4dcSmyDsnTdEHKs_r7V1n",
      "type": "text",
      "x": -1454.3234545677694,
      "y": 9168.480823952814,
      "width": 605.1841151619532,
      "height": 100,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "dashed",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bRdo",
      "roundness": null,
      "seed": 1671865702,
      "version": 1240,
      "versionNonce": 1695897184,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1782521087651,
      "link": null,
      "locked": false,
      "text": "É a categoria que abrange interações quando o usuário inicia\na conversa e abre uma janela de 24 h de atendimento. Dentro\ndessa janela, as mensagens de negócio podem ser enviadas\nsem custo extra de template",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "É a categoria que abrange interações quando o usuário inicia a conversa e abre uma janela de 24 h de atendimento. Dentro dessa janela, as mensagens de negócio podem ser enviadas sem custo extra de template",
      "autoResize": false,
      "lineHeight": 1.25
    },
