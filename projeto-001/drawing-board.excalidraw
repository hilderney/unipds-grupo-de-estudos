    {
      "id": "TrpYQkHJ8TJkHssac9JMr",
      "type": "text",
      "x": -2039.5863339830094,
      "y": -742.4149937340949,
      "width": 487.3197021484375,
      "height": 50,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#a5d8ff",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "dashed",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [
        "-h0BQcrKjhdSxGQkEPRZN"
      ],
      "frameId": null,
      "index": "b31",
      "roundness": null,
      "seed": 236558717,
      "version": 1000,
      "versionNonce": 755885984,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1782521087650,
      "link": null,
      "locked": false,
      "text": "Apesar de importante, não dependa do\nWhatsapp, pois hoje é o Whatsapp, mas e amanhã?",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Apesar de importante, não dependa do\nWhatsapp, pois hoje é o Whatsapp, mas e amanhã?",
      "autoResize": true,
      "lineHeight": 1.25
    },
